{
    "name": "codechap/yii3-context-trimmer",
    "description": "Yii3 text preprocessor for trimming and optimising content for LLM context windows.",
    "type": "library",
    "license": "MIT",
    "keywords": ["yii3", "llm", "context", "trimmer", "tokenizer", "ai"],
    "autoload": {
        "psr-4": {
            "Codechap\\Yii3ContextTrimmer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Codechap\\Yii3ContextTrimmer\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "CodeChap",
            "email": "hello@codechap.com"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "extra": {
        "config-plugin-options": {
            "source-directory": "config"
        },
        "config-plugin": {
            "di": "di.php"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "platform": {
            "php": "8.2.0"
        }
    }
}
