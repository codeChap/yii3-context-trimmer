{
    "name": "codechap/yii3-context-trimmer",
    "description": "Yii3 text preprocessor for trimming and optimising content for LLM context windows.",
    "type": "library",
    "license": "MIT",
    "keywords": ["yii3", "llm", "context", "trimmer", "tokenizer", "ai"],
    "autoload": {
        "psr-4": {
            "Codechap\\Yii3ContextTrimmer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Codechap\\Yii3ContextTrimmer\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "CodeChap",
            "email": "hello@codechap.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "symfony/console": "^6.0 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^2.0"
    },
    "suggest": {
        "yiisoft/yii-console": "Required for using the context:trim console command with the Yii3 console runner"
    },
    "extra": {
        "config-plugin-options": {
            "source-directory": "config"
        },
        "config-plugin": {
            "params": "params.php",
            "params-console": [
                "$params",
                "params-console.php"
            ],
            "di": "di.php",
            "di-console": "$di"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse"
    },
    "config": {
        "platform": {
            "php": "8.2.0"
        }
    }
}
