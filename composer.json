{
    "name": "codechap/yii3-context-trimmer",
    "description": "Tokenizer-agnostic text preprocessor for trimming and optimising content for LLM context windows.",
    "type": "library",
    "license": "MIT",
    "keywords": ["yii3", "llm", "context", "trimmer", "tokenizer", "ai"],
    "autoload": {
        "psr-4": {
            "Codechap\\Yii3ContextTrimmer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Codechap\\Yii3ContextTrimmer\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "CodeChap",
            "email": "hello@codechap.com"
        }
    ],
    "require": {
        "php": "8.2 - 8.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "vimeo/psalm": "^5.0 || ^6.0",
        "symfony/console": "^6.0 || ^7.0"
    },
    "suggest": {
        "symfony/console": "Required for using the context:trim console command",
        "yiisoft/yii-console": "Required for running the context:trim command with the Yii3 console runner"
    },
    "extra": {
        "config-plugin-options": {
            "source-directory": "config",
            "merge-plan-file": "../tests/environment/.merge-plan.php"
        },
        "config-plugin": {
            "params": "params.php",
            "params-console": [
                "$params",
                "params-console.php"
            ],
            "di": "di.php",
            "di-console": "$di"
        }
    },
    "scripts": {
        "test": "phpunit --testdox",
        "analyse": "psalm"
    },
    "config": {
        "platform": {
            "php": "8.2.0"
        }
    }
}
